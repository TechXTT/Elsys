{
  "$description": "ТУЕС / Elsys design tokens — Direction A 'Наследството' (decision D-13). W3C Design Tokens format, importable into Figma via Tokens Studio or buildable via Plugin API. Source anchors: live site theme-color #017AE0; legacy palette verification happens in M1.1 — if extracted CSS disagrees, M1.1 values win and this file is updated.",
  "primitive": {
    "brand": {
      "50":  { "$type": "color", "$value": "#E5F2FC" },
      "100": { "$type": "color", "$value": "#BFDFF8" },
      "200": { "$type": "color", "$value": "#8FC7F2" },
      "300": { "$type": "color", "$value": "#5AACE9" },
      "400": { "$type": "color", "$value": "#2F94E4" },
      "500": { "$type": "color", "$value": "#017AE0", "$description": "Brand azure — site theme-color" },
      "600": { "$type": "color", "$value": "#0163B4" },
      "700": { "$type": "color", "$value": "#014C8A" },
      "800": { "$type": "color", "$value": "#023A69" },
      "900": { "$type": "color", "$value": "#042C53", "$description": "Navy ink — heading color" }
    },
    "gray": {
      "50":  { "$type": "color", "$value": "#F9FAFB" },
      "100": { "$type": "color", "$value": "#F2F4F6" },
      "200": { "$type": "color", "$value": "#E4E7EB" },
      "300": { "$type": "color", "$value": "#CBD2D9" },
      "400": { "$type": "color", "$value": "#9AA5B1" },
      "500": { "$type": "color", "$value": "#7B8794" },
      "600": { "$type": "color", "$value": "#616E7C" },
      "700": { "$type": "color", "$value": "#52606D" },
      "800": { "$type": "color", "$value": "#3E4C59" },
      "900": { "$type": "color", "$value": "#1F2933" }
    },
    "coral": {
      "50":  { "$type": "color", "$value": "#FDEEEC" },
      "100": { "$type": "color", "$value": "#F9CFC8" },
      "200": { "$type": "color", "$value": "#F4A79B" },
      "300": { "$type": "color", "$value": "#EF7F6E" },
      "400": { "$type": "color", "$value": "#F0594F", "$description": "Legacy accent red-coral (e.g. numbers labels)" },
      "500": { "$type": "color", "$value": "#D9432F" },
      "600": { "$type": "color", "$value": "#B23423" },
      "700": { "$type": "color", "$value": "#8C2819" },
      "800": { "$type": "color", "$value": "#661C10" },
      "900": { "$type": "color", "$value": "#401008" }
    },
    "green": {
      "100": { "$type": "color", "$value": "#C0DD97" },
      "500": { "$type": "color", "$value": "#3B6D11" },
      "800": { "$type": "color", "$value": "#27500A" }
    },
    "amber": {
      "100": { "$type": "color", "$value": "#FAC775" },
      "500": { "$type": "color", "$value": "#854F0B" },
      "800": { "$type": "color", "$value": "#633806" }
    },
    "purple": {
      "100": { "$type": "color", "$value": "#E6E4F4" },
      "500": { "$type": "color", "$value": "#534AB7" },
      "800": { "$type": "color", "$value": "#322B6E" }
    },
    "teal": {
      "100": { "$type": "color", "$value": "#D5EDE7" },
      "500": { "$type": "color", "$value": "#0F6E56" },
      "800": { "$type": "color", "$value": "#0A4A3A" }
    },
    "gold": {
      "100": { "$type": "color", "$value": "#FAE3BC" },
      "500": { "$type": "color", "$value": "#BA7517" },
      "800": { "$type": "color", "$value": "#5A3206" }
    },
    "white": { "$type": "color", "$value": "#FFFFFF" }
  },
  "color": {
    "$description": "Semantic layer. Two modes: light (default) and dark. CSS var names = code syntax for Figma variables.",
    "bg": {
      "page":     { "$type": "color", "$value": "{primitive.white}",    "$extensions": { "dark": "{primitive.gray.900}", "css": "var(--color-bg-page)" } },
      "surface":  { "$type": "color", "$value": "{primitive.white}",    "$extensions": { "dark": "#283441", "css": "var(--color-bg-surface)" } },
      "subtle":   { "$type": "color", "$value": "#F4F9FD",              "$extensions": { "dark": "#24303C", "css": "var(--color-bg-subtle)" } },
      "header":   { "$type": "color", "$value": "{primitive.brand.600}","$extensions": { "dark": "{primitive.brand.800}", "css": "var(--color-bg-header)" }, "$description": "brand/600: white on-brand small text = 6.1:1 (brand/500 was 4.32:1). Dark stays brand/800." },
      "footer":   { "$type": "color", "$value": "{primitive.brand.800}","$extensions": { "dark": "#0E1822", "css": "var(--color-bg-footer)" } },
      "brand-tint": { "$type": "color", "$value": "{primitive.brand.50}", "$extensions": { "dark": "{primitive.brand.900}", "css": "var(--color-bg-brand-tint)" } }
    },
    "text": {
      "heading":  { "$type": "color", "$value": "{primitive.brand.900}","$extensions": { "dark": "{primitive.brand.100}", "css": "var(--color-text-heading)" } },
      "body":     { "$type": "color", "$value": "{primitive.gray.800}", "$extensions": { "dark": "{primitive.gray.200}", "css": "var(--color-text-body)" } },
      "muted":    { "$type": "color", "$value": "{primitive.gray.600}", "$extensions": { "dark": "{primitive.gray.400}", "css": "var(--color-text-muted)" } },
      "on-brand": { "$type": "color", "$value": "{primitive.white}",    "$extensions": { "dark": "{primitive.white}", "css": "var(--color-text-on-brand)" } },
      "link":     { "$type": "color", "$value": "{primitive.brand.600}","$extensions": { "dark": "{primitive.brand.300}", "css": "var(--color-text-link)" } },
      "accent":   { "$type": "color", "$value": "{primitive.coral.600}","$extensions": { "dark": "{primitive.coral.300}", "css": "var(--color-text-accent)" }, "$description": "coral/600 (6.16:1 on white) — coral/500 was 4.38:1, fails AA for small text. Dark stays coral/300. Used by PostCard eyebrow + NumberStat." }
    },
    "action": {
      "primary":        { "$type": "color", "$value": "{primitive.brand.600}", "$extensions": { "dark": "{primitive.brand.400}", "css": "var(--color-action-primary)" }, "$description": "brand/600: white-on-primary = 6.1:1 (brand/500 was 4.32:1, failed AA). Dark mode pending separate contrast check." },
      "primary-hover":  { "$type": "color", "$value": "{primitive.brand.700}", "$extensions": { "dark": "{primitive.brand.300}", "css": "var(--color-action-primary-hover)" } },
      "secondary-border": { "$type": "color", "$value": "{primitive.brand.500}", "$extensions": { "dark": "{primitive.brand.300}", "css": "var(--color-action-secondary-border)" } },
      "disabled-bg":    { "$type": "color", "$value": "{primitive.gray.200}", "$extensions": { "dark": "{primitive.gray.700}", "css": "var(--color-action-disabled-bg)" } },
      "disabled-text":  { "$type": "color", "$value": "{primitive.gray.400}", "$extensions": { "dark": "{primitive.gray.500}", "css": "var(--color-action-disabled-text)" } },
      "focus-ring":     { "$type": "color", "$value": "{primitive.brand.300}", "$extensions": { "dark": "{primitive.brand.400}", "css": "var(--color-action-focus-ring)" } }
    },
    "border": {
      "default": { "$type": "color", "$value": "{primitive.gray.200}", "$extensions": { "dark": "{primitive.gray.700}", "css": "var(--color-border-default)" } },
      "strong":  { "$type": "color", "$value": "{primitive.gray.300}", "$extensions": { "dark": "{primitive.gray.600}", "css": "var(--color-border-strong)" } }
    },
    "status": {
      "success-bg":   { "$type": "color", "$value": "{primitive.green.100}", "$extensions": { "dark": "{primitive.green.800}", "css": "var(--color-status-success-bg)" } },
      "success-text": { "$type": "color", "$value": "{primitive.green.800}", "$extensions": { "dark": "{primitive.green.100}", "css": "var(--color-status-success-text)" } },
      "warning-bg":   { "$type": "color", "$value": "{primitive.amber.100}", "$extensions": { "dark": "{primitive.amber.800}", "css": "var(--color-status-warning-bg)" } },
      "warning-text": { "$type": "color", "$value": "{primitive.amber.800}", "$extensions": { "dark": "{primitive.amber.100}", "css": "var(--color-status-warning-text)" } },
      "danger-bg":    { "$type": "color", "$value": "{primitive.coral.50}",  "$extensions": { "dark": "{primitive.coral.800}", "css": "var(--color-status-danger-bg)" } },
      "danger-text":  { "$type": "color", "$value": "{primitive.coral.700}", "$extensions": { "dark": "{primitive.coral.100}", "css": "var(--color-status-danger-text)" } }
    },
    "tag-tint": {
      "$description": "Accessible Badge/CategoryLabel backgrounds (light tint). Always paired with tag-ink text + a solid tag dot. All pairs pass WCAG AA (small text) in both modes.",
      "blue":   { "$type": "color", "$value": "{primitive.brand.50}",   "$extensions": { "dark": "{primitive.brand.900}",  "css": "var(--color-tag-tint-blue)" } },
      "green":  { "$type": "color", "$value": "{primitive.green.100}",  "$extensions": { "dark": "{primitive.green.800}",  "css": "var(--color-tag-tint-green)" } },
      "coral":  { "$type": "color", "$value": "{primitive.coral.50}",   "$extensions": { "dark": "{primitive.coral.800}",  "css": "var(--color-tag-tint-coral)" } },
      "purple": { "$type": "color", "$value": "{primitive.purple.100}", "$extensions": { "dark": "{primitive.purple.800}", "css": "var(--color-tag-tint-purple)" } },
      "teal":   { "$type": "color", "$value": "{primitive.teal.100}",   "$extensions": { "dark": "{primitive.teal.800}",   "css": "var(--color-tag-tint-teal)" } },
      "amber":  { "$type": "color", "$value": "{primitive.gold.100}",   "$extensions": { "dark": "{primitive.gold.800}",   "css": "var(--color-tag-tint-amber)" } }
    },
    "tag-ink": {
      "$description": "Text/foreground for accessible badges, paired with tag-tint.",
      "blue":   { "$type": "color", "$value": "{primitive.brand.700}",  "$extensions": { "dark": "{primitive.brand.100}",  "css": "var(--color-tag-ink-blue)" } },
      "green":  { "$type": "color", "$value": "{primitive.green.800}",  "$extensions": { "dark": "{primitive.green.100}",  "css": "var(--color-tag-ink-green)" } },
      "coral":  { "$type": "color", "$value": "{primitive.coral.700}",  "$extensions": { "dark": "{primitive.coral.100}",  "css": "var(--color-tag-ink-coral)" } },
      "purple": { "$type": "color", "$value": "{primitive.purple.800}", "$extensions": { "dark": "{primitive.purple.100}", "css": "var(--color-tag-ink-purple)" } },
      "teal":   { "$type": "color", "$value": "{primitive.teal.800}",   "$extensions": { "dark": "{primitive.teal.100}",   "css": "var(--color-tag-ink-teal)" } },
      "amber":  { "$type": "color", "$value": "{primitive.gold.800}",   "$extensions": { "dark": "{primitive.gold.100}",   "css": "var(--color-tag-ink-amber)" } }
    }
  },
  "spacing": {
    "$description": "4px base. CSS syntax var(--spacing-N).",
    "2xs": { "$type": "dimension", "$value": "4px" },
    "xs":  { "$type": "dimension", "$value": "8px" },
    "sm":  { "$type": "dimension", "$value": "12px" },
    "md":  { "$type": "dimension", "$value": "16px" },
    "lg":  { "$type": "dimension", "$value": "24px" },
    "xl":  { "$type": "dimension", "$value": "32px" },
    "2xl": { "$type": "dimension", "$value": "48px" },
    "3xl": { "$type": "dimension", "$value": "64px" },
    "4xl": { "$type": "dimension", "$value": "96px" }
  },
  "radius": {
    "none": { "$type": "dimension", "$value": "0px" },
    "sm":   { "$type": "dimension", "$value": "4px" },
    "md":   { "$type": "dimension", "$value": "8px" },
    "lg":   { "$type": "dimension", "$value": "12px" },
    "full": { "$type": "dimension", "$value": "9999px" }
  },
  "typography": {
    "$description": "Families resolved in M1.1 (legacy font extraction + licensing). Heading candidate: rounded geometric matching legacy (Comfortaa-like); body: Cyrillic-complete sans. Sizes in px, line-height unitless.",
    "family": {
      "heading": { "$type": "fontFamily", "$value": "TBD-M1.1-heading", "$extensions": { "css": "var(--font-heading)" } },
      "body":    { "$type": "fontFamily", "$value": "TBD-M1.1-body",    "$extensions": { "css": "var(--font-body)" } }
    },
    "scale": {
      "display":  { "$type": "typography", "$value": { "fontSize": "48px", "lineHeight": 1.15, "fontWeight": 700 } },
      "h1":       { "$type": "typography", "$value": { "fontSize": "38px", "lineHeight": 1.2,  "fontWeight": 700 } },
      "h2":       { "$type": "typography", "$value": { "fontSize": "30px", "lineHeight": 1.25, "fontWeight": 700 } },
      "h3":       { "$type": "typography", "$value": { "fontSize": "24px", "lineHeight": 1.3,  "fontWeight": 600 } },
      "h4":       { "$type": "typography", "$value": { "fontSize": "20px", "lineHeight": 1.35, "fontWeight": 600 } },
      "body-lg":  { "$type": "typography", "$value": { "fontSize": "18px", "lineHeight": 1.6,  "fontWeight": 400 } },
      "body":     { "$type": "typography", "$value": { "fontSize": "16px", "lineHeight": 1.6,  "fontWeight": 400 } },
      "body-sm":  { "$type": "typography", "$value": { "fontSize": "14px", "lineHeight": 1.5,  "fontWeight": 400 } },
      "caption":  { "$type": "typography", "$value": { "fontSize": "13px", "lineHeight": 1.4,  "fontWeight": 400 } },
      "overline": { "$type": "typography", "$value": { "fontSize": "12px", "lineHeight": 1.3,  "fontWeight": 600, "letterSpacing": "0.06em", "textCase": "uppercase" } }
    }
  },
  "tag": {
    "$description": "ColorTag enum (Club/News color tags) — solid tag colour, used for dots/accents/bands. For text labels use the accessible color.tag-tint + color.tag-ink pair instead (solid + white text fails WCAG AA for small text on coral/amber/blue).",
    "blue":   { "$type": "color", "$value": "{primitive.brand.500}",  "$extensions": { "css": "var(--color-tag-blue)" } },
    "green":  { "$type": "color", "$value": "{primitive.green.500}",  "$extensions": { "css": "var(--color-tag-green)" } },
    "coral":  { "$type": "color", "$value": "{primitive.coral.400}",  "$extensions": { "css": "var(--color-tag-coral)" } },
    "purple": { "$type": "color", "$value": "{primitive.purple.500}", "$extensions": { "css": "var(--color-tag-purple)" } },
    "teal":   { "$type": "color", "$value": "{primitive.teal.500}",   "$extensions": { "css": "var(--color-tag-teal)" } },
    "amber":  { "$type": "color", "$value": "{primitive.gold.500}",   "$extensions": { "css": "var(--color-tag-amber)" } }
  }
}

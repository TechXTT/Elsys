# Database
DATABASE_URL="postgres://USER:PASSWORD@HOST:5432/postgres?sslmode=require"
PRISMA_DATABASE_URL="prisma+postgres://accelerate.prisma-data.net/?api_key=YOUR_PRISMA_ACCELERATE_API_KEY"

# Auth (set strong secret in production)
NEXTAUTH_SECRET="changeme-super-secret"
# For local dev you can omit NEXTAUTH_URL; on deploy set to your site URL
# NEXTAUTH_URL="http://localhost:3000"

# Vercel Blob storage (required for admin image uploads)
BLOB_READ_WRITE_TOKEN=""

# Initial admin bootstrap (optional for seeding)
ADMIN_EMAIL="admin@elsys.bg"
ADMIN_PASSWORD="admin123"

# Redis cache (optional — caches degrade to in-memory without it)
# Local dev: docker run -d -p 6379:6379 redis:7-alpine
# REDIS_URL="redis://127.0.0.1:6379"

# DeepL auto-translate (optional — translation becomes a no-op without it)
# DEEPL_API_KEY=""

# Admin registration endpoint (keep disabled in production)
# ALLOW_ADMIN_REGISTRATION="false"

# Full reference: docs/runbooks/ENV_VARS.md
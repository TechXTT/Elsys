// Prisma schema for NextAuth with credentials (password on User)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("PRISMA_DATABASE_URL")
}

model User {
  id             String    @id @default(cuid())
  name           String?
  firstName      String?
  lastName       String?
  email          String?   @unique
  emailVerified  DateTime?
  image          String?
  // Credentials auth support
  password       String?
  role           Role      @default(USER)
  gradeLevel     Int?
  gradeClass     GradeClass?

  accounts       Account[]
  sessions       Session[]
  auditLogs      AuditLog[]
  oneTimeSecrets OneTimeSecret[]
  pages          Page[]
  newsPosts      NewsPost[]
  pageVersionsCreated PageVersion[]
  newsPostVersionsCreated NewsPostVersion[]
  carousels       Carousel[]
  clubs           Club[]

  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

enum Role {
  USER
  ADMIN
}

enum GradeClass {
  A
  B
  V
  G
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  action    String
  entity    String?
  entityId  String?
  details   Json?
  ip        String?
  userAgent String?
  createdAt DateTime @default(now())

  @@index([entity, entityId])
  @@index([userId, createdAt])
}

enum SecretType {
  INITIAL_PASSWORD
  RESET_PASSWORD
}

model OneTimeSecret {
  id        String     @id @default(cuid())
  token     String     @unique
  userId    String
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      SecretType
  secret    String?
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime   @default(now())

  @@index([userId, type, createdAt])
}

/// Editable CMS pages managed via the admin console
model Page {
  id           String   @id @default(cuid())
  // Slug now represents only the local path segment (not full path)
  slug         String   // e.g. "home" or "some-page"
  locale       String   // e.g. "bg" | "en"
  /// Group identifier to link the same logical node across locales (temporarily optional for backfill)
  groupId      String?
  title        String
  excerpt      String?
  bodyMarkdown String?
  blocks       Json?
  /// Legacy boolean — kept and dual-written during the R3 transition (drop after M1 soak, PLAN §8).
  published    Boolean  @default(true)
  /// Canonical publication state (R3). Public visibility = isPublic() in lib/content/shared.ts.
  status       PublishStatus @default(PUBLISHED)

  // Navigation hierarchy & presentation (merged from NavigationItem)
  parentId     String?
  parent       Page?    @relation("PageHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children     Page[]   @relation("PageHierarchy")
  order        Int      @default(0)
  visible      Boolean  @default(true)
  externalUrl  String?  // When set and kind=LINK, treat as external navigation link
  routePath    String?  // When kind=ROUTE, base route path (e.g. "pages/news") without locale prefix
  routeOverride String? // Optional absolute/relative route to override href building
  accessRole   Role?    // Optional role gating for visibility
  navLabel     String?  // Optional override label separate from title
  kind         PageKind @default(PAGE)

  authorId     String?
  author       User?    @relation(fields: [authorId], references: [id], onDelete: SetNull)

  // Versioning (optional): current published version pointer and all versions
  currentVersionId String?
  currentVersion   PageVersion? @relation("CurrentPageVersion", fields: [currentVersionId], references: [id])
  versions         PageVersion[]

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([slug, locale])
  @@index([slug, locale])
  @@index([locale, status]) // For hierarchical lookups filtering by publication status (R3)
  @@index([locale, parentId, slug]) // Critical for hierarchical path resolution (avoids N+1)
  @@index([groupId])
  @@index([parentId, order])
}

/// News posts previously stored in filesystem (JSON + Markdown)
model NewsPost {
  /// Slug used in URLs (e.g. "my-article"). Kept as `id` for backward compatibility with PostItem.
  id            String
  /// Locale of the post (e.g. "bg" | "en"). Defaults to project default at write time.
  locale        String
  title         String
  excerpt       String?
  /// Markdown body content
  bodyMarkdown  String
  /// Block-based content stored as JSON
  blocks        Json?
  /// Whether the post uses block editor (true) or markdown (false)
  useBlocks     Boolean  @default(false)
  /// Publish date
  date          DateTime
  /// Array of images: [{ name, url, size }]
  images        Json?
  /// Featured image URL (card cover)
  featuredImage String?
  /// Legacy boolean — kept and dual-written during the R3 transition (drop after M1 soak, PLAN §8).
  published     Boolean  @default(true)
  /// Canonical publication state (R3). Public visibility = isPublic() (status PUBLISHED + date <= now).
  status        PublishStatus @default(PUBLISHED)

  authorId      String?
  author        User?    @relation(fields: [authorId], references: [id], onDelete: SetNull)

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@id([id, locale])
  @@index([date])
  /// Composite index to speed locale + status + date queries (R3)
  @@index([locale, status, date])
}

/// Version history for news posts (for rollback functionality)
/// Shared across all locales of the same article (identified by newsPostId/slug)
/// Note: This references the slug only, not the specific locale variant
model NewsPostVersion {
  id            String   @id @default(cuid())
  newsPostId    String

  version       Int
  title         String
  excerpt       String?
  bodyMarkdown  String
  blocks        Json?
  useBlocks     Boolean  @default(false)
  date          DateTime
  images        Json?
  featuredImage String?
  published     Boolean  @default(true)

  createdById   String?
  createdBy     User?    @relation(fields: [createdById], references: [id], onDelete: SetNull)
  createdAt     DateTime @default(now())

  @@index([newsPostId, version])
  @@index([newsPostId, createdAt])
}

/// Version snapshots of pages (drafts or published)
model PageVersion {
  id            String   @id @default(cuid())
  pageId        String
  page          Page     @relation(fields: [pageId], references: [id], onDelete: Cascade)
  version       Int
  title         String
  excerpt       String?
  bodyMarkdown  String?
  blocks        Json?
  published     Boolean  @default(false)
  createdById   String?
  createdBy     User?    @relation(fields: [createdById], references: [id], onDelete: SetNull)
  createdAt     DateTime @default(now())

  // Back-reference: some pages may point to this as currentVersion via a named relation
  Page          Page[]   @relation("CurrentPageVersion")

  @@index([pageId, version])
}

/// Editable navigation items (tree structure)
model NavigationItem {
  id          String   @id @default(cuid())
  parentId    String?
  parent      NavigationItem? @relation("NavToChildren", fields: [parentId], references: [id], onDelete: SetNull)
  children    NavigationItem[] @relation("NavToChildren")
  order       Int      @default(0)
  // Internal link slug (like a page slug) or external URL
  slug        String?
  externalUrl String?
  visible     Boolean  @default(true)
  accessRole  Role?
  // Localized labels: { "bg": "Начало", "en": "Home" }
  labels      Json
  meta        Json?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([parentId, order])
}

/// Page kind clarifies how a page participates in navigation / content
enum PageKind {
  PAGE    // Standard content page (editable blocks/markdown)
  LINK    // External URL (no content body)
  FOLDER  // Structural grouping without content (can still have locale variants for label)
  ROUTE   // References an existing app route; uses routePath for href (supports subpaths)
}

/// Content lifecycle status shared across all content types (§4.1)
enum PublishStatus {
  DRAFT
  PREVIEW
  PUBLISHED
  SCHEDULED
  ARCHIVED
}

/// Color tag used by content types that display a color accent (Club, Gallery, etc.)
enum ColorTag {
  RED
  ORANGE
  YELLOW
  GREEN
  TEAL
  BLUE
  INDIGO
  PURPLE
  PINK
  GRAY
}

/// Student clubs — rendered as ClubGrid / ClubSpotlight blocks and at /uchenicheski-jivot/klubove/[slug]
model Club {
  id              String        @id @default(cuid())
  locale          String        @default("bg")
  slug            String
  title           String
  description     String?
  body            Json?
  color           ColorTag      @default(BLUE)
  coverImage      String?
  gallery         Json?
  meetingSchedule String?
  contactEmail    String?
  status          PublishStatus @default(DRAFT)
  order           Int           @default(0)
  publishAt       DateTime?
  unpublishAt     DateTime?
  legacyId        Int?

  authorId        String?
  author          User?         @relation(fields: [authorId], references: [id], onDelete: SetNull)

  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@unique([slug, locale])
  @@index([locale, status, order])
}

/// Hero carousel slides — rendered as CarouselHero block (§4.3 #1)
model Carousel {
  id           String        @id @default(cuid())
  locale       String        @default("bg")
  title        String
  subtitle     String?
  imageDesktop String
  imageTablet  String?
  imagePhone   String?
  linkUrl      String?
  linkLabel    String?
  status       PublishStatus @default(PUBLISHED)
  order        Int           @default(0)
  publishAt    DateTime?
  unpublishAt  DateTime?
  legacyId     Int?

  authorId     String?
  author       User?         @relation(fields: [authorId], references: [id], onDelete: SetNull)

  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@index([locale, status, order])
}
